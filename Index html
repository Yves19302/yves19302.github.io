<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BTB - Burundi Trade Business</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    body { font-family: system-ui, sans-serif; }
    .hero-bg { background: linear-gradient(135deg, #0ea5e9 0%, #10b981 100%); }
    .tab-active { border-bottom: 4px solid #10b981; color: #10b981; font-weight: bold; }
  </style>
</head>
<body class="bg-gray-50 text-gray-900">

  <!-- Hero -->
  <header class="hero-bg text-white py-20 text-center px-4">
    <h1 class="text-6xl font-bold">BTB</h1>
    <p class="text-3xl mt-2">Burundi Trade Business</p>
    <p class="mt-6 max-w-2xl mx-auto text-lg">Innovative app to create, manage and trade products seamlessly for entrepreneurs in Burundi and the world.</p>
  </header>

  <div class="max-w-5xl mx-auto px-6 py-12">
    <h2 class="text-4xl font-bold text-center mb-10">Five Main Tabs of BTB App</h2>

    <div class="flex flex-wrap justify-center gap-4 border-b pb-4 mb-12">
      <button onclick="show(0)" class="tab-active px-5 py-3" id="tab0">💬 Chat</button>
      <button onclick="show(1)" class="px-5 py-3" id="tab1">🛒 Marketplace</button>
      <button onclick="show(2)" class="px-5 py-3" id="tab2">📦 Orders</button>
      <button onclick="show(3)" class="px-5 py-3" id="tab3">🛎️ Notifications</button>
      <button onclick="show(4)" class="px-5 py-3" id="tab4">👤 Profile</button>
    </div>

    <div id="content" class="bg-white rounded-3xl shadow-xl p-10 min-h-[400px] text-center text-xl"></div>
  </div>

  <script>
    const contents = [
      "💬 <strong>AI Chatbot</strong><br>Ask anything about trading, payments, security. Remembers conversation.",
      "🛒 <strong>Marketplace</strong><br>Browse products, search, filter, add to cart, wishlist.",
      "📦 <strong>Orders</strong><br>Track all your orders from purchase to delivery.",
      "🛎️ <strong>Notifications</strong><br>Real-time alerts for orders, deals and updates.",
      "👤 <strong>Profile</strong><br>Manage account, payments, settings and verification."
    ];

    function show(n) {
      document.getElementById("content").innerHTML = `<p>${contents[n]}</p>`;
      document.querySelectorAll("button").forEach(b => b.classList.remove("tab-active"));
      document.getElementById("tab" + n).classList.add("tab-active");
    }
    show(0);
  </script>

</body>
</html>
