<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BTB - Burundi Trade Business</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    body { font-family: system-ui, sans-serif; }
    .hero { background: linear-gradient(135deg, #0ea5e9, #10b981); }
  </style>
</head>
<body class="bg-gray-50">

  <div class="hero text-white text-center py-24">
    <h1 class="text-6xl font-bold">BTB</h1>
    <p class="text-3xl mt-3">Burundi Trade Business</p>
    <p class="max-w-lg mx-auto mt-6 text-lg">Smart trading app for entrepreneurs in Burundi and worldwide.</p>
  </div>

  <div class="max-w-5xl mx-auto px-6 py-12">
    <h2 class="text-3xl font-bold text-center mb-10">Five Main Tabs</h2>

    <div class="flex flex-wrap justify-center gap-6 border-b pb-6 mb-10">
      <button onclick="switchTab(0)" class="font-bold text-xl active-tab">💬 Chat</button>
      <button onclick="switchTab(1)" class="font-bold text-xl">🛒 Marketplace</button>
      <button onclick="switchTab(2)" class="font-bold text-xl">📦 Orders</button>
      <button onclick="switchTab(3)" class="font-bold text-xl">🛎️ Notifications</button>
      <button onclick="switchTab(4)" class="font-bold text-xl">👤 Profile</button>
    </div>

    <div id="content" class="text-center text-xl min-h-[300px]">
      <p>💬 <strong>AI Chatbot</strong> - Ask anything about trading and payments.</p>
    </div>
  </div>

  <script>
    function switchTab(n) {
      const texts = [
        "💬 AI Chatbot - Ready to help you with trading, payments & security.",
        "🛒 Marketplace - Browse products, add to cart, filter easily.",
        "📦 Orders - Track your purchases and deliveries in real time.",
        "🛎️ Notifications - Get alerts for orders and special offers.",
        "👤 Profile - Manage your account and settings."
      ];
      document.getElementById("content").innerHTML = `<p class="text-2xl">${texts[n]}</p>`;
    }
  </script>
</body>
</html>
